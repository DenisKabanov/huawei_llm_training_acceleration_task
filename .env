WORKING_DIR = "./" # path to the folder where the work will be done (can leave "./" if the notebook is in the same folder as the rest of the requirements files...)
DATA_DIR = "data/" # path to subfolder in WORKING_DIR with data
MODELS_DIR = "models/" # path to subfolder in WORKING_DIR with models
RESULTS_DIR = "results/" # path to subfolder in WORKING_DIR with results
DATASET_NAME = "Elriggs/openwebtext-100k" # training dataset name
MODEL_NAME = "Qwen/Qwen2.5-0.5B" # model name
EVAL_BENCHMARKS_TRAINING = ["piqa", "winogrande"] # list of benchmarks that will be calculated during training (not all benchmarks so as not to slow down learning too much)
# EVAL_BENCHMARKS = ["piqa", "arc_easy", "arc_challenge", "winogrande", "hellaswag"] # list of benchmarks that will be calculated during the final evaluation of the model (includes the heaviest benchmarks)

MAX_SAMPLES = 4000 # max samples from data
MAX_SEQUENCE_LEN = 256 # the optimal number of tokens in the document (padding if not enough, truncation if too much), determined by the histogram of tokens distribution across selected samples or by the hardware limit
TEST_SIZE = 0.1 # test proportion of dataset

EPOCHS = 20 # max epochs training
EPOCHS_PATIENCE = 3 # number of epochs without changing the tracked metric, after which training will stop (if EPOCHS_PATIENCE=3, then we will tolerate the lack of improvement three times, and interrupt it the fourth time)
TOLERANCE = 1 # tolerance to changes in the convergence of weights (how much minimum should the L2-norm of updating weights change after the training epoch in order not to cause an early stopping)
LEARNING_RATE = 0.00002 # learning rate for optimizers Muon is very sensitive to the learning step, unlike Adam, it does not scale updates by elements (point-wise), but updates the "direction" of the matrix)
WEIGHT_DECAY = 0.1 # the size of the penalty for weights during training (L2-regularization prevents weights from becoming too large ~ overfitting, that is, if there is not so much data or the model is too large, then this parameter should be greater and, conversely, if there is a lot of data and the model is small, then it is better to set the value less than or even 0)
SCHEDULER_STEP = 4 # after how many epochs should the learning rate be changed to improve convergence
SCHEDULER_GAMMA = 0.5 # scheduler coefficient for learning rate
BATCH_SIZE = 4 # batch size (the number of samples transmitted to the model at the same time => the higher the value, the faster the learning, but the worse the quality due to the accumulation of gradients)
VERBOSE = 1 # how often should training logs be displayed
RANDOM_STATE = 42 # number for setting randomness

FORCE_USE_PREPROCESSED_DATA = True # force use of early preprocessed dataset in advance
OPTIMIZER = "AdamW" # weights optimizer (possible values "AdamW", "Muon", "Muon_with_AdamW")
TRACKED_METRIC = "AVG benchmarks acc" # tracked metric for early stopping (besides convergence of weights)
DEVICE = "auto" # which device should be used for training ("cpu", "cuda" or "auto" for automatic selection)